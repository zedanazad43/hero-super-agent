# hero-agent — Environment Variables
# Copy to ../.env (project root) or set in your shell before running `npm run hero:start`.
# Tokens marked [required] must be set for the platform to show ✅ in /api/status.

# ── GitHub ──────────────────────────────────────────────────────────────────────
# Scopes needed: repo, read:user
GITHUB_TOKEN=<your-github-pat>                    # [required]

# ── Cloudflare ───────────────────────────────────────────────────────────────────
# Create at: https://dash.cloudflare.com/profile/api-tokens
CLOUDFLARE_API_TOKEN=<cfut_...>                   # [required]

# ── Railway ──────────────────────────────────────────────────────────────────────
# Create at: https://railway.app/account/tokens
RAILWAY_API_TOKEN=<your-railway-token>            # [required]

# ── Stripe ───────────────────────────────────────────────────────────────────────
# Live or test secret key from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=<sk_live_...>                   # [required]

# ── Wallet (MetaMask / Alchemy) ───────────────────────────────────────────────────
METAMASK_ADDRESS=<0x...>                          # [required] Ethereum wallet address
METAMASK_PRIVATE_KEY=<0x...>                      # [optional] Only used for format check, never transmitted
ALCHEMY_ETHEREUM_ENDPOINT=<https://eth-mainnet.g.alchemy.com/v2/...>  # [optional]

# ── Manus ────────────────────────────────────────────────────────────────────────
MANUS_API_KEY=<your-manus-key>                    # [required]
MANUS_ENDPOINT=https://api.manus.ai               # [optional, defaults to above]

# ── Hero Agent Server ─────────────────────────────────────────────────────────────
PORT=3001                                         # [optional] HTTP port, default 3001
AIMASTER_ENDPOINT=http://127.0.0.1:8000           # [optional] Python aimaster HTTP endpoint
