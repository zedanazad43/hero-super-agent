{
  "name": "hero-super-agent",
  "version": "1.0.0",
  "description": "Hero Super Agent - Advanced AI Trading Advisor for DeFi",
  "type": "module",
  "main": "server.js",
  "scripts": {
    "dev": "node server.js",
    "start": "node server.js",
    "build": "npm run build:cloudflare && npm run build:api && npm run build:web",
    "build:cloudflare": "cd packages/cloudflare && npm install && npm run build",
    "build:api": "cd packages/api && npm install",
    "build:web": "cd packages/web && npm install",
    "deploy": "npm run build && bash scripts/deploy/deploy.sh",
    "deploy:dry": "cd packages/cloudflare && wrangler deploy --dry-run",
    "test": "echo 'Tests configured in packages/*/package.json'",
    "lint": "eslint . --ext .js,.jsx,.mjs",
    "check:secrets": "node scripts/check/security-audit.js --secrets-only",
    "verify": "npm run lint && npm run check:secrets && npm run deploy:dry",
    "verify:prod": "npm run build && npm run verify",
    "smoke:prod": "node scripts/check/verify-production-endpoints.js",
    "monitor": "node scripts/monitor/monitor-performance.js",
    "db:migrate": "wrangler d1 execute hero-super-agent-db --remote --file=./migrations/schema.sql",
    "freebuff:status": "node -e \"import('./src/agents/freebuff-agent.js').then(m => console.log('FreeBuff Agent Ready'))\"",
    "freebuff:scan": "node -e \"console.log('🔍 Scanning FreeBuff opportunities...')\"",
    "freebuff:execute": "node -e \"console.log('⚡ Executing FreeBuff tasks (using FREE models)')\"",
    "orchestrator:start": "node -e \"console.log('🦸 Starting Hero Master Orchestrator (FREE-only)')\"",
    "orchestrator:status": "node -e \"console.log('📊 Hero Orchestrator Status')\"",
    "profit:daily": "node -e \"console.log('🦸 Running daily orchestration (6am UTC)')\"",
    "profit:continuous": "node -e \"console.log('💰 Running profit orchestration every 30 min')\""
  },
  "dependencies": {},
  "devDependencies": {
    "eslint": "^9.0.0",
    "wrangler": "^4.86.0"
  }
}
